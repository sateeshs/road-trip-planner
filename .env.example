# AI — OpenRouter (free models available at https://openrouter.ai/models?q=free)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Hotel search (free sandbox — https://developers.amadeus.com)
AMADEUS_CLIENT_ID=your_amadeus_client_id_here
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret_here

# Places & attractions (free tier — https://foursquare.com/developers)
FOURSQUARE_API_KEY=your_foursquare_api_key_here

# Road routing (free tier — https://openrouteservice.org/dev)
OPENROUTESERVICE_API_KEY=your_openrouteservice_api_key_here
ORS_APP_NAME=road-trip-planner

# App URL (used in OpenRouter attribution headers)
NEXT_PUBLIC_APP_URL=https://road-trip-planner-blush.vercel.app
